{
  "name": "platepulse",
  "version": "1.0.0",
  "private": true,
  "description": "PlatePulse - A modern diet planning application",
  "scripts": {
    "dev": "pnpm --filter \"./apps/**\" dev",
    "build": "pnpm --filter \"./apps/**\" build",
    "test": "pnpm --filter \"./apps/**\" test",
    "lint": "pnpm --filter \"./apps/**\" lint",
    "typecheck": "pnpm --filter \"./apps/**\" typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "db:generate": "pnpm --filter @platepulse/database prisma generate",
    "db:migrate": "pnpm --filter @platepulse/database prisma migrate dev",
    "db:studio": "pnpm --filter @platepulse/database prisma studio"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "typescript": "5.x",
    "prettier": "3.x",
    "eslint": "8.x",
    "turbo": "1.x"
  }
}
